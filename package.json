{
  "name": "@vacinc/search-fusion",
  "version": "0.2.2",
  "description": "Federated OpenClaw web search fusion that fans out across configured providers, merges results, and preserves attribution.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VACInc/openclaw-search-fusion.git"
  },
  "homepage": "https://github.com/VACInc/openclaw-search-fusion#readme",
  "bugs": {
    "url": "https://github.com/VACInc/openclaw-search-fusion/issues"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.9",
      "minGatewayVersion": "2026.4.9"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.4.9"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "check": "tsc --noEmit",
    "test": "node --test --experimental-test-module-mocks --import tsx test/**/*.test.ts",
    "plugin:check": "plugin-inspector check --no-openclaw",
    "plugin:check:runtime": "node ./scripts/plugin-inspector-runtime.mjs check --no-openclaw --runtime --mock-sdk --allow-execute",
    "plugin:ci": "node ./scripts/plugin-inspector-runtime.mjs ci --no-openclaw --runtime --mock-sdk --allow-execute"
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.4.9"
  },
  "devDependencies": {
    "@openclaw/plugin-inspector": "0.3.10",
    "@sinclair/typebox": "0.34.48",
    "@types/node": "^22.15.30",
    "openclaw": "2026.5.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
